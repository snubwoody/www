---
import { getCollection } from "astro:content";
import { ChevronRight } from "@lucide/astro/icons";

let articles = await getCollection("articles", (post) => {
    return post.data.preview !== true;
});
articles = articles.splice(0, 5);
---

<div class="space-y-8">
    <h6>Similar articles</h6>
    <ul class="space-y-4">
        {
            articles.map((article) => (
                <>
                    <a
                        href={`/blog/${article.id}`}
                        class="flex items-center justify-between text-accent"
                    >
                        <p>{article.data.title}</p>
                    </a>
                </>
            ))
        }
    </ul>
</div>
